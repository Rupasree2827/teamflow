{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",
    
    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,

    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",


    "types": ["node"]
  },

  "include": ["src"],

  "exclude": ["node_modules", "dist"]
}